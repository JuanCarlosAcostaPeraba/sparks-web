---
import RoadmapDetailSection from "../components/RoadmapDetailSection.astro";
import RoadmapVisual from "../components/RoadmapVisual.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Layout from "../layouts/Layout.astro";
import { roadmapSeo, roadmapStructuredData } from "../config/seo";
import { footerContent, navItems } from "../data/home";
import { roadmapPageContent } from "../data/roadmap";

const roadmapNavItems = navItems.map((item) => ({
  ...item,
  href: item.label === "Roadmap" ? "/roadmap" : item.href,
}));
---

<Layout
  title={roadmapSeo.title}
  description={roadmapSeo.description}
  canonicalPath={roadmapSeo.path}
  structuredData={roadmapStructuredData}
>
  <SiteHeader navItems={roadmapNavItems} />
  <main>
    <section class="mx-auto w-full max-w-6xl px-5 py-20 md:py-28">
      <a class="text-sm font-black text-ember hover:text-ink" href="/">
        Back to home
      </a>
      <div class="mt-8 grid gap-10 md:grid-cols-[0.9fr_1.1fr] md:items-end">
        <div>
          <h1
            class="max-w-2xl text-6xl font-black leading-none tracking-tight text-ink md:text-7xl"
          >
            {roadmapPageContent.hero.title}
          </h1>
          <p class="mt-7 max-w-2xl text-xl leading-8 text-muted">
            {roadmapPageContent.hero.description}
          </p>
        </div>
        <p class="text-lg leading-8 text-muted">
          {roadmapPageContent.overview}
        </p>
      </div>
      <div class="mt-14">
        <RoadmapVisual steps={roadmapPageContent.items} />
      </div>
    </section>
    <RoadmapDetailSection items={roadmapPageContent.items} />
  </main>
  <SiteFooter content={footerContent} />
</Layout>
