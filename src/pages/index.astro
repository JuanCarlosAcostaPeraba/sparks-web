---
import CommandsSection from "../components/CommandsSection.astro";
import FeatureSection from "../components/FeatureSection.astro";
import HeroSection from "../components/HeroSection.astro";
import InstallSection from "../components/InstallSection.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Layout from "../layouts/Layout.astro";
import {
  commands,
  commandsIntro,
  features,
  footerContent,
  heroContent,
  installIntro,
  installOptions,
  navItems,
  terminalLines,
  whyIntro,
} from "../data/home";
---

<Layout>
  <SiteHeader navItems={navItems} />
  <main>
    <HeroSection content={heroContent} terminalLines={terminalLines} />
    <FeatureSection intro={whyIntro} features={features} />
    <CommandsSection intro={commandsIntro} commands={commands} />
    <InstallSection intro={installIntro} options={installOptions} />
  </main>
  <SiteFooter content={footerContent} />
</Layout>
