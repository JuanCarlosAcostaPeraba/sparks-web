---
interface Props {
  lines: readonly string[];
}

const { lines } = Astro.props;
---

<div
  class="w-full max-w-[320px] min-w-0 overflow-hidden rounded-lg border border-neutral-800 bg-neutral-950 shadow-[0_28px_90px_rgba(32,25,12,0.18)] sm:max-w-none"
  aria-label="sparks command-line demo"
>
  <div
    class="flex h-10 items-center gap-2 border-b border-neutral-800 bg-neutral-900 px-4"
  >
    <span class="h-3 w-3 rounded-full bg-red-400"></span>
    <span class="h-3 w-3 rounded-full bg-amber-400"></span>
    <span class="h-3 w-3 rounded-full bg-green-400"></span>
    <span class="ml-auto font-mono text-[10px] font-bold tracking-wide text-stone-500">sparks — shell</span>
  </div>
  <pre
    class="whitespace-pre-wrap wrap-break-word p-5 font-mono text-[11px] leading-6 text-stone-100 sm:overflow-x-auto sm:whitespace-pre sm:p-7 sm:text-sm"
    set:html={lines.join("\n")}
  />
</div>
