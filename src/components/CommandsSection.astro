---
import type {
  CommandExample,
  SectionIntro as SectionIntroType,
} from "../types/site";

interface Props {
  intro: SectionIntroType;
  commands: readonly CommandExample[];
}

const { intro, commands } = Astro.props;
---

<section id="commands" class="border-t border-line py-24">
  <div
    class="mx-auto grid w-full max-w-6xl gap-10 px-5 md:grid-cols-[0.9fr_1.1fr]"
  >
    <div>
      <h2
        class="max-w-xl text-balance text-5xl font-black leading-none tracking-tight text-ink md:text-6xl"
      >
        {intro.title}
      </h2>
      <p class="mt-7 max-w-xl text-pretty text-lg leading-8 text-muted">
        {intro.description}
      </p>
    </div>
    <div>
      {
        commands.map((example) => (
          <div class="group grid gap-2 border-b border-line py-4 sm:grid-cols-[220px_1fr] sm:gap-6">
            <code class="font-mono text-sm font-black text-ember">
              <span class="mr-2 text-spark" aria-hidden="true">$</span>{example.command}
            </code>
            <span class="text-muted">{example.description}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
