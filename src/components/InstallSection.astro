---
import SectionIntro from "./SectionIntro.astro";
import type {
  InstallOption,
  SectionIntro as SectionIntroType,
} from "../types/site";

interface Props {
  intro: SectionIntroType;
  options: readonly InstallOption[];
}

const { intro, options } = Astro.props;
---

<section id="install" class="border-t border-line py-24">
  <div class="mx-auto w-full max-w-6xl px-5">
    <SectionIntro intro={intro} />
    <div class="mt-12 grid gap-5 md:grid-cols-2">
      {
        options.map((option) => (
          <article class="rounded-lg border border-line bg-panel p-7">
            <h3 class="text-2xl font-black text-ink">{option.title}</h3>
            <p class="mt-3 text-muted">{option.description}</p>
            <pre
              class="mt-5 overflow-x-auto rounded-lg bg-neutral-950 p-5 font-mono text-xs leading-6 text-stone-100"
              set:html={option.commands.join("\n")}
            />
          </article>
        ))
      }
    </div>
  </div>
</section>
