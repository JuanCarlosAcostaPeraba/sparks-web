---
import SectionIntro from "./SectionIntro.astro";
import CopyCommand from "./CopyCommand.astro";
import type {
  InstallOption,
  SectionIntro as SectionIntroType,
} from "../types/site";

interface Props {
  intro: SectionIntroType;
  options: readonly InstallOption[];
}

const { intro, options } = Astro.props;
---

<section id="install" class="border-t border-line py-24">
  <div class="mx-auto w-full max-w-6xl px-5">
    <SectionIntro intro={intro} />
    <div class="mt-12 grid gap-5 md:grid-cols-2">
      {
        options.map((option) => (
          <article class="flex h-full flex-col rounded-lg border border-line bg-panel p-7">
            <span class="font-mono text-xs font-black uppercase tracking-[0.16em] text-ember">
              {option.id === "windows" ? "PowerShell" : "Shell"}
            </span>
            <h3 class="mt-4 text-2xl font-black text-ink">{option.title}</h3>
            <p class="mt-3 text-pretty text-muted">{option.description}</p>
            <div class="mt-auto pt-5">
              <CopyCommand command={option.commands.join("\n")} multiline />
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
