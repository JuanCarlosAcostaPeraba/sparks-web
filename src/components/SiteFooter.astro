---
import type { FooterContent } from "../types/site";

interface Props {
  content: FooterContent;
}

const { content } = Astro.props;
---

<footer class="border-t border-neutral-700 bg-neutral-950 py-20 text-white">
  <div
    class="mx-auto w-full max-w-6xl px-5"
  >
    <div class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="max-w-3xl text-balance text-5xl font-black leading-none tracking-tight">
          {content.title}
        </h2>
        <p class="mt-5 max-w-2xl text-pretty text-lg leading-8 text-stone-300">
          {content.description}
        </p>
      </div>
      <a
        class="inline-flex h-11 shrink-0 items-center justify-center rounded-lg border border-white bg-white px-5 text-sm font-black text-neutral-950 transition-transform duration-150 hover:-translate-y-0.5 active:scale-[0.96] motion-reduce:transition-none"
        href={content.action.href}
        target="_blank"
        rel="noopener noreferrer"
      >
        {content.action.label}
      </a>
    </div>

    <div class="mt-14 flex flex-col gap-3 border-t border-neutral-800 pt-5 font-mono text-xs text-stone-400 sm:flex-row sm:items-center sm:justify-between">
      <a
        class="w-fit transition-colors duration-150 hover:text-spark focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-spark"
        href={content.credit.href}
        target="_blank"
        rel="noopener noreferrer"
      >
        {content.credit.label}
      </a>
      <span class="text-stone-600" aria-hidden="true">local-first / open source</span>
    </div>
  </div>
</footer>
