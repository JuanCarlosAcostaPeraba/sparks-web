---
import type { RoadmapStep } from "../types/site";

interface Props {
  steps: readonly RoadmapStep[];
}

const { steps } = Astro.props;

const accentClasses = {
  spark: "border-[#64d67a] bg-[#64d67a] text-[#15130f]",
  ember: "border-ember bg-ember text-[#15130f]",
  ink: "border-ink bg-ink text-panel",
} as const;

const statusLabels = {
  now: "Now",
  next: "Next",
  later: "Later",
} as const;
---

<div class="grid gap-4 md:grid-cols-3">
  {
    steps.map((step, index) => (
      <article class="relative rounded-lg border border-line bg-panel p-6">
        {index < steps.length - 1 && (
          <div class="absolute top-10 right-0 hidden h-px w-8 translate-x-full bg-line md:block" />
        )}
        <div class="flex items-center justify-between gap-4">
          <span
            class:list={[
              "grid h-12 w-12 place-items-center rounded-full border text-sm font-black",
              accentClasses[step.accent],
            ]}
          >
            {step.phase}
          </span>
          <span class="rounded-full border border-line px-3 py-1 text-xs font-black uppercase tracking-[0.16em] text-muted">
            {statusLabels[step.status]}
          </span>
        </div>
        <h3 class="mt-6 text-2xl font-black leading-tight text-ink">
          {step.title}
        </h3>
        <p class="mt-4 leading-7 text-muted">{step.description}</p>
      </article>
    ))
  }
</div>
